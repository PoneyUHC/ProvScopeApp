{
    "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
    "include": [
        "src/preload/*.d.ts",
        "src/renderer/env.d.ts",
        "src/renderer/**/*",
        "src/renderer/**/*.tsx",
        "src/common/**/*",
        "src/common/**/*.tsx"
    ],
    "compilerOptions": {
        "composite": true,
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@renderer/*": [
                "src/renderer/*"
            ],
            "@common/*": [
                "src/common/*"
            ],
        }
    }
}
